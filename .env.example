# QuestDP — environment variables (Vite, prefix VITE_*)
# Copy this file to `.env` and fill values. `.env` is gitignored.

# --- Supabase ---
# Project URL — public.
VITE_SUPABASE_URL=https://zkglnbfdoftfwkwrobox.supabase.co
# Publishable / anon key — safe for client. Found in Dashboard → Project Settings → API.
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# --- Toss Payments ---
# Client Key — 공개 안전. 결제창 호출 (브라우저). 토스 대시보드 → 개발자센터 → API 키.
# 테스트 키: test_ck_*  /  라이브 키: live_ck_*
VITE_TOSS_CLIENT_KEY=test_ck_DpexMgkW36LkdK0w1qpL3GbR5ozO

# --- Server-side scripts & Edge Functions only (절대 client 에 노출 X) ---
# Service role 키 — RLS 우회. 월간 보고서 (npm run report) 등 운영 스크립트 전용.
# .env.local 에 따로 보관 권장 (이 파일은 git 에 들어가지만 .env.local 은 .gitignore 됨).
# Dashboard → Project Settings → API → service_role secret
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...
#
# Toss Secret Key — Edge Function 만 사용 (서버 결제 confirm). 절대 클라이언트 X.
# Supabase secrets 에 저장: `supabase secrets set TOSS_SECRET_KEY=live_sk_xxx`
# TOSS_SECRET_KEY=test_sk_...
